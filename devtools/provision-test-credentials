"""Provision test credentials for extenddb integration tests.

Creates a test account, IAM user, access key, and full-access policy via
the management API. Outputs shell export statements for the provisioned
credentials. Also imports the ``dummy-key``/``dummy-secret`` pair used by
the external Java test suite.

Usage:
    eval $(devtools/provision-test-credentials)

Requires:
    EXTENDDB_TEST_ENDPOINT  — server URL (e.g. https://127.0.0.1:8000)
    EXTENDDB_ADMIN_USER     — admin username (default: admin)
    EXTENDDB_ADMIN_PASSWORD — admin password from ``extenddb init``
"""

from __future__ import annotations

import json
import os
import sys
import urllib3

import requests

# Suppress InsecureRequestWarning for self-signed certs.
urllib3.disable_warnings(urllib3.exceptions.InsecureRequestWarning)

ACCOUNT_ID = "123456789012"
ACCOUNT_NAME = "test-account"
USER_NAME = "test-user"
POLICY_NAME = "full-access"
FULL_ACCESS_POLICY = {
    "Version": "2012-10-17",
    "Statement": [{"Effect": "Allow", "Action": "dynamodb:*", "Resource": "*"}],
}
# Credentials used by the external Java test suite (hardcoded in DynamoDBTestBase.java).
# These don't pass AKIA format validation, so we create proper keys instead.
# The Java tests will need to be updated to use env vars (tracked as follow-up).
JAVA_USER_NAME = "java-test-user"


def main() -> int:
    endpoint = os.environ.get("EXTENDDB_TEST_ENDPOINT", "").strip()
    admin_user = os.environ.get("EXTENDDB_ADMIN_USER", "admin").strip()
    admin_pass = os.environ.get("EXTENDDB_ADMIN_PASSWORD", "").strip()

    if not endpoint:
        print("error: EXTENDDB_TEST_ENDPOINT is not set", file=sys.stderr)
        return 1
    if not admin_pass:
        print("error: EXTENDDB_ADMIN_PASSWORD is not set", file=sys.stderr)
        return 1

    base = endpoint.rstrip("/") + "/management"
    auth = (admin_user, admin_pass)
    verify = not endpoint.startswith("https://")

    def post(path: str, body: dict | None = None) -> requests.Response:
        return requests.post(f"{base}{path}", json=body, auth=auth,
                             verify=verify, timeout=30)

    def put(path: str, body: dict) -> requests.Response:
        return requests.put(f"{base}{path}", json=body, auth=auth,
                            verify=verify, timeout=30)

    # 1. Create account (idempotent — 409 means it already exists).
    r = post("/accounts", {"account_id": ACCOUNT_ID, "account_name": ACCOUNT_NAME})
    if r.status_code not in (201, 409):
        print(f"error: create account failed: {r.status_code} {r.text}", file=sys.stderr)
        return 1
    print(f"# account {ACCOUNT_ID}: {'created' if r.status_code == 201 else 'exists'}",
          file=sys.stderr)

    # 2. Create test user.
    r = post(f"/accounts/{ACCOUNT_ID}/users", {"user_name": USER_NAME})
    if r.status_code not in (201, 409):
        print(f"error: create user failed: {r.status_code} {r.text}", file=sys.stderr)
        return 1
    print(f"# user {USER_NAME}: {'created' if r.status_code == 201 else 'exists'}",
          file=sys.stderr)

    # 3. Create access key for test user.
    # NOTE: This creates a new key on every invocation.  Repeated runs
    # accumulate orphaned keys.  Acceptable for ephemeral test users.
    r = post(f"/accounts/{ACCOUNT_ID}/users/{USER_NAME}/access-keys")
    if r.status_code != 201:
        print(f"error: create access key failed: {r.status_code} {r.text}", file=sys.stderr)
        return 1
    key_data = r.json()
    access_key = key_data["access_key_id"]
    secret_key = key_data["secret_access_key"]
    print(f"# access key created: {access_key}", file=sys.stderr)

    # 4. Attach full-access policy.
    r = put(f"/accounts/{ACCOUNT_ID}/users/{USER_NAME}/policy/{POLICY_NAME}",
            FULL_ACCESS_POLICY)
    if r.status_code not in (200, 201, 204):
        print(f"error: put policy failed: {r.status_code} {r.text}", file=sys.stderr)
        return 1
    print(f"# policy {POLICY_NAME}: attached", file=sys.stderr)

    # 5. Create Java test user with proper credentials.
    # The external Java tests hardcode "dummy-key"/"dummy-secret" which don't
    # pass AKIA format validation. Create a proper key instead — the Java tests
    # will need to be updated to use env vars (tracked as follow-up).
    r = post(f"/accounts/{ACCOUNT_ID}/users", {"user_name": JAVA_USER_NAME})
    if r.status_code not in (201, 409):
        print(f"error: create java user failed: {r.status_code} {r.text}", file=sys.stderr)
        return 1
    print(f"# user {JAVA_USER_NAME}: {'created' if r.status_code == 201 else 'exists'}",
          file=sys.stderr)

    r = put(f"/accounts/{ACCOUNT_ID}/users/{JAVA_USER_NAME}/policy/{POLICY_NAME}",
            FULL_ACCESS_POLICY)
    if r.status_code not in (200, 201, 204):
        print(f"error: put java policy failed: {r.status_code} {r.text}", file=sys.stderr)
        return 1

    r = post(f"/accounts/{ACCOUNT_ID}/users/{JAVA_USER_NAME}/access-keys")
    if r.status_code == 201:
        java_creds = r.json()
        print(f"# java access key created: {java_creds['access_key_id']}", file=sys.stderr)
    else:
        print(f"# java access key: skipped (user may already have keys)", file=sys.stderr)

    # Output export statements to stdout (eval-able).
    print(f"export AWS_ACCESS_KEY_ID={access_key}")
    print(f"export AWS_SECRET_ACCESS_KEY={secret_key}")
    print(f"export AWS_DEFAULT_REGION=us-east-1")
    return 0


if __name__ == "__main__":
    sys.exit(main())
