#
# S4 smoke test verification script.
#
# Automates the principal reviewer's manual smoke test:
#   1. Verify server is running and healthy
#   2. Run `extenddb manage list-admins`
#   3. Create a table via AWS CLI over HTTPS
#   4. Verify table exists via DescribeTable
#   5. Delete the test table
#
# Usage:
#   devtools/verify-smoke [--config PATH]
#
# Requires:
#   EXTENDDB_TEST_ENDPOINT  — server URL (e.g. https://localhost:8000)
#   AWS_ACCESS_KEY_ID       — valid credentials for the target
#   AWS_SECRET_ACCESS_KEY   — valid credentials for the target
#   EXTENDDB_ADMIN_PASSWORD — admin password (for manage commands)
#
# This script never prompts for input. All required values come from
# environment variables or CLI flags.

set -euo pipefail
exec < /dev/null  # Never read from stdin

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
cd "$PROJECT_DIR"

CONFIG="extenddb.toml"
while [[ $# -gt 0 ]]; do
    case "$1" in
        --config) CONFIG="$2"; shift 2 ;;
        *) echo "error: unknown option: $1"; exit 1 ;;
    esac
done

BINARY="target/release/extenddb"
if [[ ! -x "$BINARY" ]]; then
    BINARY="target/debug/extenddb"
fi
if [[ ! -x "$BINARY" ]]; then
    echo "error: extenddb binary not found. Build with: cargo build --release"
    exit 1
fi

ENDPOINT="${EXTENDDB_TEST_ENDPOINT:-}"
if [[ -z "$ENDPOINT" ]]; then
    echo "error: EXTENDDB_TEST_ENDPOINT is not set"
    exit 1
fi

ADMIN_PASS="${EXTENDDB_ADMIN_PASSWORD:-}"
if [[ -z "$ADMIN_PASS" ]]; then
    echo "error: EXTENDDB_ADMIN_PASSWORD is not set"
    exit 1
fi

echo "=== S4 Smoke Test Verification ==="
echo "  endpoint: $ENDPOINT"
echo "  config:   $CONFIG"
echo "  binary:   $BINARY"
echo ""

PASS=0
FAIL=0

check() {
    local desc="$1"
    shift
    if "$@" >/dev/null 2>&1; then
        echo "  ✓ $desc"
        PASS=$((PASS + 1))
    else
        echo "  ✗ $desc"
        FAIL=$((FAIL + 1))
    fi
}

# 1. Health check
echo "--- Step 1: Health check"
check "Server is healthy" curl -skf "$ENDPOINT/health"

# 2. List admins
echo "--- Step 2: Management API"
ADMIN_USER="${EXTENDDB_ADMIN_USER:-admin}"
check "list-admins succeeds" "$BINARY" manage --config "$CONFIG" \
    --user "$ADMIN_USER" --password "$ADMIN_PASS" list-admins

# 3. Create table via AWS CLI
echo "--- Step 3: Create table via AWS CLI"
TABLE_NAME="smoke-test-$(date +%s)"
AWS_ARGS=(--endpoint-url "$ENDPOINT" --region us-east-1 --no-verify-ssl)

if aws dynamodb create-table \
    "${AWS_ARGS[@]}" \
    --table-name "$TABLE_NAME" \
    --attribute-definitions AttributeName=pk,AttributeType=S \
    --key-schema AttributeName=pk,KeyType=HASH \
    --billing-mode PAY_PER_REQUEST \
    >/dev/null 2>&1; then
    echo "  ✓ CreateTable succeeded: $TABLE_NAME"
    PASS=$((PASS + 1))
else
    echo "  ✗ CreateTable failed"
    FAIL=$((FAIL + 1))
fi

# 4. Wait for ACTIVE and verify
echo "--- Step 4: Verify table"
ATTEMPTS=0
while [[ $ATTEMPTS -lt 30 ]]; do
    STATUS=$(aws dynamodb describe-table "${AWS_ARGS[@]}" \
        --table-name "$TABLE_NAME" 2>/dev/null \
        | python3 -c "import sys,json; print(json.load(sys.stdin)['Table']['TableStatus'])" 2>/dev/null || echo "UNKNOWN")
    if [[ "$STATUS" == "ACTIVE" ]]; then
        break
    fi
    sleep 0.5
    ATTEMPTS=$((ATTEMPTS + 1))
done

if [[ "$STATUS" == "ACTIVE" ]]; then
    echo "  ✓ Table is ACTIVE"
    PASS=$((PASS + 1))
else
    echo "  ✗ Table status: $STATUS (expected ACTIVE)"
    FAIL=$((FAIL + 1))
fi

# 5. Cleanup: delete the test table
echo "--- Step 5: Cleanup"
if aws dynamodb delete-table "${AWS_ARGS[@]}" \
    --table-name "$TABLE_NAME" >/dev/null 2>&1; then
    echo "  ✓ DeleteTable succeeded"
    PASS=$((PASS + 1))
else
    echo "  ✗ DeleteTable failed"
    FAIL=$((FAIL + 1))
fi

echo ""
echo "=== Results: $PASS passed, $FAIL failed ==="
if [[ $FAIL -gt 0 ]]; then
    exit 1
fi
